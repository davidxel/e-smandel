# Salin ke .env lokal (jangan commit .env berisi sandi produksi).

# MySQL — buat database dulu: CREATE DATABASE e_smandel CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=e_smandel

# API
PORT=3001
JWT_SECRET=ganti-dengan-string-acak-panjang

# Set 1 jika koneksi MySQL memerlukan SSL
# MYSQL_SSL=1
